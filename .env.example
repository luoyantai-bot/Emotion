# ============================================================
# 🧘 情绪管理与智能坐垫干预系统 - 环境变量配置
# ============================================================
# 
# 使用方法:
#   1. 复制此文件为 .env:  cp .env.example .env
#   2. 填入你的真实配置
#   3. 重启服务:  node server/index.js
# ============================================================

# ── 服务器配置 ──
PORT=8000

# ── 前端配置 (Vite 使用) ──
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_API_MODE=live

# ── 硅基流动 AI 大模型配置 ──
# 
# 获取 API Key: https://cloud.siliconflow.cn/account/ak
# 1. 注册/登录硅基流动账号
# 2. 进入 "API密钥" 页面
# 3. 创建新的 API Key
# 4. 粘贴到下方
#
SILICONFLOW_API_KEY=sk-gstrukbduzzpqcmboarwirwanfjgqwnscgpnsscwzntbboad

# 可选：选择模型 (默认 deepseek-ai/DeepSeek-V3)
# 支持的模型:
#   deepseek-ai/DeepSeek-V3          - 综合能力强，性价比高（推荐）
#   deepseek-ai/DeepSeek-R1          - 推理增强型，分析更深入
#   Qwen/Qwen2.5-72B-Instruct       - 阿里通义千问，中文能力优秀
#   Pro/Qwen/Qwen2.5-7B-Instruct    - 轻量快速，适合实时场景
#   THUDM/glm-4-9b-chat             - 清华智谱
#
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3

# 可选：自定义 API 地址 (一般不需要改)
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
